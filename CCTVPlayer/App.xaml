<Application x:Class="CCTVPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgColor" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="PanelColor" Color="#16213E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#E94560"/>
        <SolidColorBrush x:Key="TextColor" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="SelectedColor" Color="#0F3460"/>
        <Style x:Key="CtrlBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F3460"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
