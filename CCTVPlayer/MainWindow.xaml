<Window x:Class="CCTVPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="央视频·定制版" Height="600" Width="1100"
        MinHeight="450" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">
    <Window.Resources>
        <!-- 全局按钮: 深色悬浮替代系统亮蓝 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0F3460"/>
            <Setter Property="Foreground" Value="#EEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border x:Name="hl" CornerRadius="3" Background="#28FFFFFF" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hl" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 深色滚动条 (全局) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#445566" BorderThickness="0" Width="8">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 自定义 MenuItem 模板: 去掉左侧图标列 + 深色背景 + 深色高亮 -->
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Header" RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="SubArrow" Text="▸" FontSize="10"
                                           Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="Collapsed"/>
                                <Popup Grid.Column="0" Grid.ColumnSpan="2" x:Name="PART_Popup"
                                       IsOpen="{Binding IsSubmenuOpen,RelativeSource={RelativeSource TemplatedParent}}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="None"
                                       Placement="Right" VerticalOffset="-4">
                                    <Border Background="#16213E" BorderBrush="#0F3460" BorderThickness="1" Padding="2">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F3460"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F3460"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="SubArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="BorderBrush" Value="#0F3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkSeparator" TargetType="Separator">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Height" Value="0"/>
        </Style>
        <!-- 自定义提示框 -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Foreground" Value="#EEE"/>
            <Setter Property="BorderBrush" Value="#0F3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="10"
                      ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="OuterBorder" Background="#1A1A2E" CornerRadius="10" BorderBrush="#16213E" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 自定义标题栏 ===== -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10,10,0,0"
                MouseLeftButtonDown="TitleBar_Drag">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <Image x:Name="TitleIcon" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="央视频·定制版" FontSize="15" FontWeight="Bold"
                               Foreground="#E94560" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- 标题栏右侧: 底栏中排列3个按钮 -->
                <Grid HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Margin="2,4,4,4">
                        <Button x:Name="BtnMinimize" Content="─" Width="32" Height="32" Click="BtnMinimize_Click"
                                Background="Transparent" Foreground="#AAA" BorderThickness="0" Cursor="Hand"
                                FontSize="14" Padding="0"
                                MouseEnter="TitleBtn_MouseEnter" MouseLeave="TitleBtn_MouseLeave">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2A2D3E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnMaxRestore" Content="□" Width="32" Height="32" Click="BtnMaxRestore_Click"
                                Background="Transparent" Foreground="#AAA" BorderThickness="0" Cursor="Hand"
                                FontSize="14" Padding="0"
                                MouseEnter="TitleBtn_MouseEnter" MouseLeave="TitleBtn_MouseLeave">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2A2D3E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnClose" Content="✕" Width="32" Height="32" Click="BtnClose_Click"
                                Background="Transparent" Foreground="#E94560" BorderThickness="0" Cursor="Hand"
                                FontSize="14" Padding="0"
                                MouseEnter="TitleBtn_MouseEnter" MouseLeave="TitleBtn_MouseLeave">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="192"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Sidebar" Grid.Column="0" Background="#16213E">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchBox" Grid.Row="0" Margin="0,0,0,6" Height="28"
                             Background="#0F3460" Foreground="#888" CaretBrush="#E94560"
                             BorderThickness="0"
                             TextChanged="SearchBox_TextChanged"
                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"
                             FontSize="12" Padding="6,4" Text="🔍 搜索频道..."/>

                    <ListBox x:Name="ChannelList" Grid.Row="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#CCC" FontSize="12"
                             SelectionChanged="ChannelList_SelectionChanged"
                             MouseDoubleClick="ChannelList_MouseDoubleClick"
                             VirtualizingPanel.ScrollUnit="Item"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#CCC"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="itemBg" Background="{TemplateBinding Background}" BorderThickness="0"
                                                    CornerRadius="4" Margin="0,0,4,0">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="itemBg" Property="Background" Value="#0F3460"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Grid.Row="2" Background="#121828" CornerRadius="6,6,6,6"
                            Padding="8,4" Margin="0,6,0,0">
                        <TextBlock x:Name="StatusText" FontSize="11" Foreground="#4CAF50"
                                   TextWrapping="NoWrap" Text="就绪 · F/F11 全屏"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <wv2:WebView2 x:Name="OfficialWebView" Grid.Row="0"/>

                <Border x:Name="BottomBar" Grid.Row="1" Background="#16213E" Padding="8,4"
                        CornerRadius="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- 按钮组 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnPrev" Content="|◀" Width="34" Height="26" Click="BtnPrev_Click"
                                    Cursor="Hand" FontSize="12" ToolTip="上一频道 (←)"/>
                            <Button x:Name="BtnPlay" Content="▶ 播放" Width="60" Height="26" Click="BtnPlay_Click"
                                    Background="#E94560" Foreground="#FFF" Cursor="Hand"
                                    FontSize="11" Margin="4,0,0,0" ToolTip="播放/暂停 (Enter)"/>
                            <Button x:Name="BtnStop" Content="⏹ 停止" Width="52" Height="26" Click="BtnStop_Click"
                                    Cursor="Hand" FontSize="11" Margin="4,0,0,0" ToolTip="停止播放"/>
                            <Button x:Name="BtnNext" Content="▶|" Width="34" Height="26" Click="BtnNext_Click"
                                    Cursor="Hand" FontSize="12" Margin="4,0,0,0" ToolTip="下一频道 (→)"/>
                        </StackPanel>
                            <!-- 当前节目 (5, 绿字+暗背景) -->
                            <Border Grid.Column="1" x:Name="NowProgBorder" CornerRadius="3" Padding="6,2"
                                    Margin="8,0,4,0" VerticalAlignment="Center" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NowPlaying" Text="未播放" FontSize="12" Foreground="#E94560"
                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="Transparent" Margin="6,0,0,0"
                                            ToolTip="{Binding ElementName=NowProg, Path=Text}">
                                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled" x:Name="NowProgScroller"
                                                          CanContentScroll="False">
                                                <TextBlock x:Name="NowProg" Text="" FontSize="11" Foreground="#4CAF50"
                                                           TextTrimming="None" FontWeight="Bold"
                                                           HorizontalAlignment="Left"/>
                                            </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- 下一节目 (5, 青色+蓝紫背景, 与 NowProg 区分) -->
                            <Border Grid.Column="2" x:Name="NextProgBorder" CornerRadius="3" Padding="6,2"
                                    Margin="0,0,8,0" VerticalAlignment="Center" Background="Transparent"
                                    ToolTip="{Binding ElementName=NextProg, Path=Text}">
                                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled" x:Name="NextProgScroller"
                                              CanContentScroll="False">
                                    <TextBlock x:Name="NextProg" Text="" FontSize="11" Foreground="#4FC3F7"
                                               TextTrimming="None" HorizontalAlignment="Left"/>
                                </ScrollViewer>
                            </Border>
                        <!-- 音量 + 静音 + 全屏 -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnMute" Content="🔊" Width="26" Height="26" Click="BtnMute_Click"
                                    Background="Transparent" Foreground="#888" BorderThickness="0"
                                    Cursor="Hand" FontSize="11" Padding="0"
                                    ToolTip="静音/取消静音"/>
                            <Slider x:Name="VolSlider" Width="80" Minimum="0" Maximum="100" Value="80"
                                    ValueChanged="VolSlider_ValueChanged" VerticalAlignment="Center"/>
                            <Button Content="⛶" Width="30" Height="26" Click="BtnFull_Click"
                                    Cursor="Hand" FontSize="14" Margin="4,0,0,0" ToolTip="全屏 (F/F11)"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
